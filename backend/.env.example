# ==================================
# 智学 (ZhiXue) 后端配置模板
# 复制此文件为 .env 并根据需要修改
# ==================================

# --- 服务配置 ---
ZHIXUE_HOST=127.0.0.1
ZHIXUE_PORT=18765
ZHIXUE_DEBUG=false

# --- Ollama 配置 ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# --- 模型配置 ---
ZHIXUE_LLM_MODEL=deepseek-r1
ZHIXUE_EMBEDDING_MODEL=nomic-embed-text
ZHIXUE_EMBEDDING_DIM=768

# --- Vault 配置 ---
# 通常由启动脚本自动设置，也可手动指定
ZHIXUE_VAULT_PATH=
ZHIXUE_VAULT_NAME=

# --- RAG 配置 ---
ZHIXUE_WORKING_DIR=
ZHIXUE_PARSER=mineru
ZHIXUE_PARSE_METHOD=auto
